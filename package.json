{
  "name": "agent-context-governor",
  "version": "0.1.0",
  "description": "Local-first context and memory governor for coding agents.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/konghanyu2025-hash/agent-context-governor.git"
  },
  "bugs": {
    "url": "https://github.com/konghanyu2025-hash/agent-context-governor/issues"
  },
  "homepage": "https://github.com/konghanyu2025-hash/agent-context-governor#readme",
  "bin": {
    "agent-context": "./dist/cli/main.js",
    "agent-context-mcp": "./dist/mcp/server.js",
    "agent-memory": "./dist/cli/main.js",
    "agent-memory-mcp": "./dist/mcp/server.js"
  },
  "exports": {
    ".": "./dist/index.js"
  },
  "files": [
    "dist",
    "docs",
    "README.md",
    "README.zh-CN.md",
    "CHANGELOG.md",
    "LICENSE",
    "SECURITY.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "npm run typecheck && npm test && npm run build",
    "prepare": "npm run build",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "keywords": [
    "agent",
    "context",
    "memory",
    "token",
    "governor",
    "mcp",
    "claude-code",
    "codex"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "commander": "^14.0.1"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.13"
  }
}
